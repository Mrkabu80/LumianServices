<Worksheet ss:Name="Anleitung"><Table>
<Column ss:Width="110.0"/>
<Column ss:Width="420.0"/>
<Row>
<Cell ss:StyleID="Header"><Data ss:Type="String">Lumian Kunden-Import Vorlage</Data></Cell>
</Row>
<Row>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">So nutzen</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Kunden unter der Kopfzeile eintragen. Kopfzeile nicht ändern.</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Strasse/Nr</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Nur Strasse und Hausnummer, z.B. Musterstrasse 1.</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">PLZ/Ort</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Postleitzahl und Ort zusammen, z.B. 5600 Lenzburg.</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">LumianNr</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Leer lassen, wenn das Portal automatisch eine LM-Nummer vergeben soll.</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">EmpfohlenVon</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Optional: LM-Nummer des empfehlenden Kunden, z.B. LM1001.</Data></Cell>
</Row>
<Row>
<Cell ss:StyleID="Text"><Data ss:Type="String">Import</Data></Cell>
<Cell ss:StyleID="Text"><Data ss:Type="String">Diese Excel-Datei nach dem Ausfüllen im Portal wieder importieren.</Data></Cell>
</Row>
</Table></Worksheet>
</Workbook>